---
const {
  name = "",
  link = "",
  count = 1,
  subtasks = [100]
} = Astro.props;

const uid = `pb-${Math.random().toString(36).slice(2, 8)}`;
---

<div id={uid} class="pb-wrapper">
  <a class="pb-name" href={link} target="_blank" rel="noopener noreferrer">
    {name}
  </a>

  <div class="pb-st">
    {Array.from({ length: count }).map((_, i) => (
      <input
        class="tasks"
        placeholder={`ST ${i + 1} · ${subtasks[i] ?? ""}`}
      />
    ))}
  </div>

  <button class="submit">New</button>

  <span class="total">0</span>
</div>

<script define:vars={{ uid }}>
  const wrapper = document.getElementById(uid);
  const btn = wrapper.querySelector(".submit");
  const totalEl = wrapper.querySelector(".total");

  if (!window.__points) window.__points = new Map();

  const pointsEl = document.getElementById("points-value");

  function updateGlobal() {
    let sum = 0;
    for (const v of window.__points.values()) {
      sum += v;
    }
    pointsEl.textContent = sum;
  }

  btn.addEventListener("click", () => {
    const inputs = wrapper.querySelectorAll(".tasks");

    let total = 0;
    inputs.forEach((input) => {
      total += Number(input.value) || 0;
    });

    totalEl.textContent = total;

    window.__points.set(uid, total);
    updateGlobal();
  });
</script>

<style>
  .pb-wrapper {
    display: grid;
    grid-template-columns: 150px 800px 100px auto;
    align-items: center;
    justify-items: start;
    min-height: 44px;
    gap: 14px;
    padding: 8px 16px;
    border-bottom: 1px solid #e5e5e5;
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Inter, Arial;
    font-size: 13px;
  }

  .pb-name {
    color: #000;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pb-st {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tasks {
    width: 65px;
    height: 28px;
    padding: 4px 6px;
    font-size: 12px;
    border: 1px solid #d4d4d4;
    border-radius: 4px;
    outline: none;
    background: transparent;
    text-align: center;
    color: #444;
    line-height: 1.2;
    font-family: inherit;
    box-sizing: border-box;
  }

  .tasks::placeholder {
    font-size: 11px;
    opacity: 0.6;
  }

  .tasks:focus {
    border-color: #999;
    color: #000;
  }

  .submit {
    justify-self: start;
    width: max-content;
    height: 28px;
    padding: 4px 10px;
    font-size: 12px;
    border-radius: 4px;
    border: 1px solid #d4d4d4;
    background: transparent;
    cursor: pointer;
    line-height: 1.2;
    font-family: inherit;
    box-sizing: border-box;
  }

  .submit:hover {
    background: #f5f5f5;
  }

  .total {
    font-size: 13px;
    font-weight: 500;
  }
</style>